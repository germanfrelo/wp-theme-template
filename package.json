{
	"name": "ifis-educacion",
	"version": "0.0.1",
	"private": true,
	"description": "",
	"keywords": [],
	"homepage": "",
	"bugs": {},
	"repository": {
		"type": "git",
		"url": ""
	},
	"license": "GPL-2.0-or-later",
	"author": "",
	"type": "module",
	"main": "",
	"scripts": {
		"build": "wp-scripts build",
		"build-css": "npm run clean-dist-css && NODE_ENV=production npm run css",
		"css": "npx postcss src/css/*.css --dir dist/css",
		"clean-dist-css": "rm -r -f dist && mkdir dist",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "npm run lint:css && npm run lint:js",
		"lint:fix": "npm run lint:css:fix && npm run lint:js:fix",
		"lint:css": "stylelint --formatter verbose \"**/*.css\"",
		"lint:css:fix": "npm run lint:css -- --fix",
		"lint:js": "eslint --max-warnings 0",
		"lint:js:fix": "npm run lint:js -- --fix",
		"prepare": "husky",
		"start": "wp-scripts start",
		"test": "npm run format:check && npm run lint"
	},
	"lint-staged": {
		"*.css": [
			"stylelint",
			"prettier --write"
		],
		"*.js": [
			"eslint --max-warnings 0 --no-warn-ignored",
			"prettier --write"
		],
		"!(*.css|*.js)": [
			"prettier --write --ignore-unknown"
		]
	},
	"dependencies": {
		"clean-css": "5.3.2",
		"cssnano": "6.0.1",
		"postcss": "8.4.31",
		"postcss-cli": "10.1.0",
		"postcss-import": "15.1.0",
		"postcss-import-ext-glob": "2.1.1",
		"postcss-js": "4.0.1",
		"slugify": "1.6.6",
		"tailwindcss": "3.3.5"
	},
	"devDependencies": {
		"@eslint/js": "9.23.0",
		"@wordpress/scripts": "30.15.0",
		"eslint": "9.23.0",
		"globals": "16.0.0",
		"husky": "9.1.7",
		"lint-staged": "15.5.0",
		"postcss-nesting": "12.1.1",
		"prettier": "3.5.3",
		"stylelint": "16.16.0",
		"stylelint-config-recess-order": "6.0.0",
		"stylelint-config-standard": "37.0.0",
		"stylelint-plugin-defensive-css": "1.0.4"
	}
}
